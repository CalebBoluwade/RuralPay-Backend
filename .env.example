# HSM Configuration
HSM_MASTER_KEY=your-secure-32-character-master-key
HSM_SALT=your-secure-salt-value
HSM_KEY_STORE_PATH=./keys
HSM_TYPE=software

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=ruralpay
DATABASE_SSL_MODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# HSM Configuration
HSM_MASTER_KEY=your-master-key-here
HSM_SALT=your-salt-here
HSM_KEY_STORE_PATH=./keys
HSM_KEY_ROTATION_DAYS=30

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_EXPIRY_MINUTES=24

# Argon2 Configuration
ARGON2_TIME=1
ARGON2_MEMORY=65536
ARGON2_THREADS=4
ARGON2_KEY_LENGTH=32
ARGON2_SALT_LENGTH=16

# USSD Configuration
USSD_CODE_LENGTH=8
USSD_CODE_TIMEOUT=5m
USSD_MAX_GEN_PER_USER=5
USSD_RATE_LIMIT_WINDOW=1h
USSD_PUSH_PREFIX=PUSH
USSD_PULL_PREFIX=PULL
USSD_HASH_ITERATIONS=10000

# App Configuration
APP_SCHEME=ruralpay
APP_DOMAIN=app.ruralpay.com
APP_QR_ROUTE=pay/qr

QR_EXPIRY_MINUTES=5

# NIBSS Configuration
NIBSS_BASE_URL=https://api.nibss-plc.com.ng
NIBSS_API_KEY=your-nibss-api-key-here
NIBSS_BVN_URL=https://bvnapi.nibss-plc.com.ng

# User Limits Configuration
USER_DEFAULT_DAILY_LIMIT=500000
USER_DEFAULT_SINGLE_TX_LIMIT=100000

JWT_REFRESH_EXPIRY_DAYS=7

JWT_ISSUER=nfc-payments-backend
JWT_AUDIENCE=nfc-payments-users

# Notification Service Configuration
EXPO_ACCESS_TOKEN=your-expo-access-token-here

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_NAME=RuralPay
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

TEMPLATES_DIR=./static/templates/email

SMS_SERVICE_URL=https://api.smsprovider.com/send

# Logging
LOG_FILE=./logs/app.log
LOG_MAX_SIZE_MB=100
LOG_MAX_BACKUPS=7
LOG_MAX_AGE_DAYS=30

# CORS
CORS_ALLOWED_ORIGINS=https://app.ruralpay.com,https://dashboard.ruralpay.com
APP_VERSION=v1.0.0
APP_BASE_URL=https://yourdomain.com