# ISO20022 Callback Authentication Configuration Examples
# Copy these to your .env file and adjust values as needed

# ==============================================================================
# OPTION 1: HMAC-SHA256 Authentication (Recommended for most deployments)
# ==============================================================================

# Enable callback authentication (default: true)
ISO20022_CALLBACK_REQUIRE_AUTH=true

# Shared secret for HMAC-SHA256 signing
# Generate with: openssl rand -hex 32
# IMPORTANT: Keep this secret and rotate periodically
ISO20022_CALLBACK_HMAC_SECRET=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1

# TLS is disabled when using HMAC
ISO20022_CALLBACK_TLS_ENABLED=false

# ==============================================================================
# OPTION 2: Mutual TLS Authentication (Higher security, requires setup)
# ==============================================================================

# Uncomment these to enable mTLS instead of HMAC:
# ISO20022_CALLBACK_REQUIRE_AUTH=true
# ISO20022_CALLBACK_TLS_ENABLED=true

# Optional: Whitelist specific certificate issuers (comma-separated)
# ISO20022_CALLBACK_TLS_ALLOWED_ISSUERS=NIBSS Root CA,NIBSS Intermediate CA

# Optional: Whitelist specific certificate serial numbers (comma-separated)
# ISO20022_CALLBACK_TLS_WHITELISTED_SERIALS=123456789,987654321

# ==============================================================================
# OPTION 3: Audit Mode (Log failures but allow requests - for gradual rollout)
# ==============================================================================

# Uncomment to disable authentication requirement but still audit:
# ISO20022_CALLBACK_REQUIRE_AUTH=false

# When disabled, authentication is performed but failures are logged as warnings
# This is useful for monitoring before enforcing authentication

# ==============================================================================
# DEVELOPMENT ONLY - No Authentication
# ==============================================================================

# NEVER use in production:
# ISO20022_CALLBACK_REQUIRE_AUTH=false
# This completely disables authentication verification

# ==============================================================================
# Common HMAC Generation Examples
# ==============================================================================

# Using openssl:
# $ openssl rand -hex 32

# Using Python:
# $ python3 -c "import os; print(os.urandom(32).hex())"

# Using Node.js:
# $ node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ==============================================================================
# Integration Testing
# ==============================================================================

# Generate HMAC signature for manual testing:
# $ BODY='<Document>...</Document>'
# $ SECRET="a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1"
# $ SIGNATURE=$(echo -n "$BODY" | openssl dgst -sha256 -hmac "$SECRET" -hex | sed 's/^.* //')
# $ curl -X POST http://localhost:8080/pacs008 \
#   -H "Content-Type: application/xml" \
#   -H "X-Signature: sha256=$SIGNATURE" \
#   -d "$BODY"

# Or use the provided test script:
# $ ./test_iso20022_callbacks.sh http://localhost:8080 "$SECRET"

# ==============================================================================
# Platform-Specific Notes
# ==============================================================================

# AWS Secrets Manager:
# 1. Create secret: aws secretsmanager create-secret --name iso20022-callback-hmac
# 2. Reference in Lambda environment: viper.Get("iso20022.callback.hmac_secret")

# HashiCorp Vault:
# 1. Store: vault kv put secret/iso20022 hmac_secret=...
# 2. Retrieve via Vault client

# Docker/Kubernetes Secrets:
# 1. Create: kubectl create secret generic iso20022-callback --from-literal=hmac-secret=...
# 2. Mount to `/run/secrets/iso20022_callback_hmac_secret`
# 3. Reference in env or read from mounted file

# ==============================================================================
# Monitoring and Alerting
# ==============================================================================

# Log authentication events:
# - SUCCESS: callback.auth.hmac_verified
# - FAILURE: callback.auth.hmac_failed
# - ERROR: callback.auth.mtls_failed

# Set up alerts for:
# Pattern: "callback.auth.*_failed" with threshold > 10 in 5 minutes
# Pattern: "callback.auth" from unexpected IP ranges
